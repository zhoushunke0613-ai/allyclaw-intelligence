{
  "name": "allyclaw-intelligence-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "db:init:local": "wrangler d1 execute allyclaw-db --local --file=../migrations/001_phase1_base.sql",
    "db:init:remote": "wrangler d1 execute allyclaw-db --remote --file=../migrations/001_phase1_base.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "hono": "^4.0.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0",
    "wrangler": "^4.0.0"
  }
}
